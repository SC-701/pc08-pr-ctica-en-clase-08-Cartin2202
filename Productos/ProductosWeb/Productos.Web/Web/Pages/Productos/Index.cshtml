@page
@model Web.Pages.Productos.IndexModel
@{
}
<h1>Listado de Productos</h1>

<div class="text-center mb-4">
    <a type="button" class="btn btn-group-lg btn-success btn-lg" asp-page="./Agregar">
        <i class="bi bi-plus-square"></i> Agregar
    </a>
</div>

<div class="row">
    @if (Model.productos != null)
        @foreach (var producto in Model.productos)
        {
            <div class="col-md-4 mb-4">
                <div class="card">
                    <div class="card-body">

                        <h5 class="card-title">
                            <i class="bi bi-box-seam"></i>
                            @Html.DisplayFor(modelo => producto.Nombre)
                        </h5>

                        <h6 class="card-subtitle mb-2 text-muted">
                            ₡ @Html.DisplayFor(modelo => producto.Precio)
                        </h6>

                        <p class="card-text">
                            @Html.DisplayFor(modelo => producto.Descripcion)
                        </p>

                        <p class="card-text">
                            <strong>Stock:</strong>
                            @Html.DisplayFor(modelo => producto.Stock)
                        </p>

                        <p class="card-text">
                            <strong>Código de Barras:</strong>
                            @Html.DisplayFor(modelo => producto.CodigoBarras)
                        </p>

                        <a type="button" class="btn btn-primary" asp-page="./Detalle" asp-route-id="@producto.Id">
                            <i class="bi bi-info-square"></i> Detalle
                        </a>

                        <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@producto.Id">
                            <i class="bi bi-pencil-square"></i> Editar
                        </a>

                        <a type="button" class="btn btn-danger" asp-page="./Eliminar" asp-route-id="@producto.Id">
                            <i class="bi bi-trash3-fill"></i> Eliminar
                        </a>

                    </div>
                </div>
            </div>
        }
    else
    {
        <div class="alert alert-warning" role="alert">
            No hay productos disponibles.
        </div>
    }
</div>