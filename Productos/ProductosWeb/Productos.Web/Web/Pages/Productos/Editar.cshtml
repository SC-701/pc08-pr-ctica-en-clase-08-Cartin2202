@page
@model Web.Pages.Productos.EditarModel
@{
}
<div class="container">
    <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto">

        <form method="post">

            <div class="form-group">
                <label for="categorias">Categoría</label>
                <select asp-for="categoriaseleccionada" class="form-select" asp-items="Model.categorias" id="categorias" onchange="fetchSubCategorias()">
                    <option value="">Seleccione una categoría</option>
                </select>
            </div>

            <div class="form-group">
                <label for="subcategorias">Subcategoría</label>
                <select asp-for="subCategoriaseleccionada" class="form-select" asp-items="Model.subCategorias" id="subcategorias">
                    <option value="">Seleccione una subcategoría</option>
                </select>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="productoResponse.Nombre"></label>
                <input class="form-control" asp-for="productoResponse.Nombre" />
                <span class="text-danger" asp-validation-for="productoResponse.Nombre"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="productoResponse.Descripcion"></label>
                <input class="form-control" asp-for="productoResponse.Descripcion" />
                <span class="text-danger" asp-validation-for="productoResponse.Descripcion"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="productoResponse.Precio"></label>
                <input class="form-control" asp-for="productoResponse.Precio" />
                <span class="text-danger" asp-validation-for="productoResponse.Precio"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="productoResponse.Stock"></label>
                <input class="form-control" asp-for="productoResponse.Stock" />
                <span class="text-danger" asp-validation-for="productoResponse.Stock"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="productoResponse.CodigoBarras"></label>
                <input class="form-control" asp-for="productoResponse.CodigoBarras" />
                <span class="text-danger" asp-validation-for="productoResponse.CodigoBarras"></span>
            </div>

            <div class="text-danger" asp-validation-summary="All"></div>

            <div class="form-group mt-3">
                <a class="btn btn-primary" asp-page="./Index">Regresar</a>
                <input type="submit" value="Editar" class="btn btn-success" />
            </div>

            <input type="hidden" asp-for="productoResponse.Id">
          

        </form>
    </div>
</div>

@section Scripts {
    <script>
        async function fetchSubCategorias() {
            const categoriaID = document.getElementById('categorias').value;
            if (!categoriaID) { return; }

            try {
                const respuesta = await fetch(`?handler=ObtenerSubCategorias&categoriaID=${categoriaID}`);
                const subCategorias = await respuesta.json();
                const subCategoriasSelect = document.getElementById('subcategorias');

                subCategoriasSelect.innerHTML = '<option value="">Seleccione una subcategoría</option>';

                subCategorias.forEach(subCategoria => {
                    const option = document.createElement('option');
                    option.value = subCategoria.id;
                    option.text = subCategoria.nombre;
                    subCategoriasSelect.appendChild(option);
                });

            } catch (error) {
                console.error('Error obteniendo los datos:', error);
            }
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

